{
  "name": "zaivim-monorepo",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:ts": "pnpm --filter './packages/core' --filter './packages/engine' --filter './packages/tools' --filter './packages/skills' --filter './packages/gateway' --filter './packages/tui' test",
    "test:vim": "vint packages/vim-adapter/autoload packages/vim-adapter/plugin || true",
    "test:browser": "web-ext lint packages/browser-ext || true",
    "typecheck:downstream": "pnpm --filter @zaivim/core --filter @zaivim/engine --filter @zaivim/tools --filter @zaivim/skills --filter @zaivim/gateway typecheck",
    "lint": "eslint --config eslint.config.js packages/*/src"
  }
}
