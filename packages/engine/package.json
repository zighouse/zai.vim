{
  "name": "@zaivim/engine",
  "version": "0.1.3",
  "private": false,
  "description": "zai.vim AI engine \u2014 pipeline, provider, agent, session, security, lifecycle",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@zaivim/core": "workspace:*",
    "@zaivim/tools": "workspace:*",
    "yaml": "^2.9.0"
  }
}
