{
  "name": "@zaivim/skills",
  "version": "0.1.3",
  "private": false,
  "description": "zai.vim skills \u2014 loader, registry, adapter, hello-skill example",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@zaivim/core": "workspace:*"
  },
  "peerDependencies": {
    "@zaivim/engine": "workspace:*"
  }
}
